# NextAuth v5
AUTH_SECRET=                        # openssl rand -base64 32 — MUST match backend
AUTH_GOOGLE_ID=                     # optional: Google OAuth client ID
AUTH_GOOGLE_SECRET=                 # optional: Google OAuth client secret
NEXTAUTH_URL=http://localhost:3000  # set to production URL (https://ustaadpk.com) in Vercel

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:5000  # Railway URL in production

# Cloudinary (for client-side upload preview — not the actual upload key)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
